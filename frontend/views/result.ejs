<!DOCTYPE html>
<html>
<head>
  <title>Result</title>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
  <style>
    body { font-family: sans-serif; text-align: center; margin-top: 80px; }
    .card { display: inline-block; padding: 40px 60px; border-radius: 16px;
            background: <%= approved ? '#dcfce7' : '#fee2e2' %>; }
    h1 { font-size: 2.5rem; color: <%= approved ? '#16a34a' : '#dc2626' %>; }
    .conf { color: #555; margin-top: 8px; }
    a { display: inline-block; margin-top: 24px; color: #4f46e5; text-decoration: none; }
  </style>
</head>
<body>
  <div class="card" id="card">
    <h1><%= approved ? '✅ Approved' : '❌ Rejected' %></h1>
    <p class="conf">Confidence: <strong><%= confidence %>%</strong></p>
    <a href="/">← Try another</a>
  </div>

  <script>
    gsap.from("#card", { scale: 0.8, opacity: 0, duration: 0.5, ease: "back.out(1.5)" });
  </script>
</body>
</html>